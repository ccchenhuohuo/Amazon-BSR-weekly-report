
# Sorftime BSR 同步 - 环境变量配置示例
# 复制此文件为 .env 并修改配置

# ============ Sorftime API 配置 ============
# SORFTIME_API_KEY=
# SORFTIME_API_URL=https://standardapi.sorftime.com/api/CategoryRequest
# SORFTIME_DOMAIN=1
# SORFTIME_TIMEOUT=120

# ============ Doris 数据库配置 ============
# 查询走 MySQL；Stream Load 写入走 HTTP。请使用你自己的 Doris 地址。
# DORIS_HOST=doris.example.internal
# DORIS_MYSQL_PORT=30930
# DORIS_STREAM_LOAD_HOST=doris-stream-load.example.internal
# DORIS_STREAM_LOAD_PORT=33060
# DORIS_STREAM_LOAD_FALLBACK_HOST=
# DORIS_STREAM_LOAD_FALLBACK_PORT=
# DORIS_USER=
# DORIS_PASSWORD=
# DORIS_DATABASE=
# DORIS_TABLE=

# ============ 数据回填配置 ============
# 最大并发数（建议不超过 8，避免 API 限流）
MAX_WORKERS=4

# 开始查询日期（YYYY-MM-DD）
START_DATE=2026-01-01

# 目标星期（默认周五）
# 支持多种格式：
# - 数字 0-6: 0=周一, 1=周二, 2=周三, 3=周四, 4=周五, 5=周六, 6=周日
# - 中文: 周一, 星期二, 周三, ..., 周日
# - 英文: monday, tuesday, wednesday, thursday, friday, saturday, sunday
# - 英文缩写: mon, tue, wed, thu, fri, sat, sun
TARGET_WEEKDAY=friday

# ============ Shell 脚本配置 ============
# 指定同步日期（YYYY-MM-DD，不设置则自动计算上个目标星期）
# BSR_SYNC_DATE=2026-04-17

# ============ 日志配置 ============
# 日志目录（默认: {skill_dir}/logs/）
# BSR_LOG_DIR=/path/to/custom/logs
