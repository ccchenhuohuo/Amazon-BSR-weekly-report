# Copy to a local .env file or export these values in your shell.
# Never commit real credentials.

# Sorftime
SORFTIME_API_KEY=
SORFTIME_DOMAIN=1
SORFTIME_TIMEOUT=120

# Doris
DORIS_HOST=doris.example.invalid
DORIS_MYSQL_PORT=30930
DORIS_STREAM_LOAD_HOST=doris-stream-load.example.invalid
DORIS_STREAM_LOAD_PORT=33060
DORIS_STREAM_LOAD_FALLBACK_HOST=
DORIS_STREAM_LOAD_FALLBACK_PORT=
DORIS_USER=
DORIS_PASSWORD=
DORIS_DATABASE=
DORIS_TABLE=

# Weekly report output
# Defaults to ./reports when unset.
SORFTIME_REPORT_OUTPUT_DIR=

# Feishu/Lark Base
FEISHU_TEMPLATE_BASE_TOKEN=
LARK_CLI_BIN=lark-cli
LARK_CLI_TIMEOUT_SECONDS=240
# Optional when lark-cli credentials live outside its default data dir.
LARKSUITE_CLI_DATA_DIR=

# BSR backfill
MAX_WORKERS=4
START_DATE=2026-01-01
TARGET_WEEKDAY=wednesday
